[[ -o interactive ]] || return

# history
HISTFILE="$HOME/.zsh_history"
HISTSIZE=20000
SAVEHIST=20000
setopt HIST_IGNORE_DUPS HIST_IGNORE_ALL_DUPS HIST_REDUCE_BLANKS INC_APPEND_HISTORY SHARE_HISTORY

# tmux: attach to main session or create it
t() {
  if command -v tmux >/dev/null 2>&1; then
    tmux attach -t main 2>/dev/null || tmux new -s main
  else
    echo "tmux not installed"
    return 1
  fi
}

# ---------- fzf ergonomics ----------
# If you already source ~/.fzf.zsh (you do on mac), these vars tune its widgets.

# Better default search command for fzf (fast, respects .gitignore)
if command -v rg >/dev/null 2>&1; then
  export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git/*"'
fi

# Ctrl-R: history with a preview pane
# (Preview just shows the command nicely; there is no "output preview" available from shell history.)
export FZF_CTRL_R_OPTS='
  --height 40%
  --layout=reverse
  --border
  --preview-window=down:4:wrap
  --preview "echo {} | sed -E \"s/^[[:space:]]*[0-9]+[[:space:]]+//\" | (command -v bat >/dev/null && bat -l sh --style=plain --color=always || cat)"
'

# Alt-C: jump to directory (if fzf provides it; it usually does via ~/.fzf.zsh)
export FZF_ALT_C_OPTS='
  --height 40%
  --layout=reverse
  --border
  --preview "command -v eza >/dev/null && eza -la --color=always {} || ls -la {}"
'

# aliases
[[ -r "$HOME/.config/zsh/aliases.zsh" ]] && source "$HOME/.config/zsh/aliases.zsh"

# ---------- Claude shell helpers (print-only; you execute manually) ----------

# Ask Claude for next-command suggestions based on minimal context.
ccmd() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "claude CLI not found — install it from https://claude.ai/download or via npm: npm install -g @anthropic-ai/claude-code"
    return 127
  fi

  local prompt="$*"
  if [[ -z "$prompt" ]]; then
    echo 'Usage: ccmd "what you want to do / what error you saw"'
    return 2
  fi

  local lastcmd
  lastcmd="$(fc -ln -1 2>/dev/null | sed 's/^[[:space:]]*//')"

  claude --print "PWD: $(pwd)
LAST_EXIT: $?
LAST_CMD: ${lastcmd:-<none>}

Request: $prompt

Return:
- likely cause (1-2 lines)
- 3-6 next diagnostic commands (copy/paste)
- 1 safe fix command if appropriate
Do NOT run anything; only print commands + brief notes."
}

# Pipe output into Claude and get diagnosis + next commands.
ccmd_in() {
  if ! command -v claude >/dev/null 2>&1; then
    echo "claude CLI not found — install it from https://claude.ai/download or via npm: npm install -g @anthropic-ai/claude-code"
    return 127
  fi

  local prompt="$*"
  [[ -z "$prompt" ]] && prompt="Explain this output and propose next diagnostic commands."

  local input
  input="$(cat)"

  claude --print "PWD: $(pwd)

OUTPUT:
$input

TASK:
$prompt

Return:
- likely cause
- next commands (copy/paste)
- what to check if this repeats
Do NOT run anything."
}

# completion
autoload -Uz compinit
compinit -C

# Helm completions — generated once and cached; regenerate by deleting the cache file
if command -v helm >/dev/null 2>&1; then
  _helm_cache="${XDG_CACHE_HOME:-$HOME/.cache}/helm-completion.zsh"
  [[ -f "$_helm_cache" ]] || helm completion zsh > "$_helm_cache" 2>/dev/null
  [[ -f "$_helm_cache" ]] && source "$_helm_cache"
fi

# Terraform completions (uses bash-compat completion)
if command -v terraform >/dev/null 2>&1; then
  autoload -U +X bashcompinit && bashcompinit
  complete -o nospace -C terraform terraform
fi

# ---------- prompt ----------
autoload -Uz vcs_info
precmd_functions+=( vcs_info )
zstyle ':vcs_info:*'     enable git
zstyle ':vcs_info:git:*' formats ' (%b)'
setopt PROMPT_SUBST
PROMPT='%F{green}%n@%m%f %F{blue}%~%f%F{yellow}${vcs_info_msg_0_}%f
%(?.%F{green}.%F{red})❯%f '

# ---------- key bindings ----------
# bindkey -e must come first — it resets the keymap to emacs defaults,
# so all custom bindings must be registered after it.

bindkey -e

# Ctrl-x Ctrl-e: edit current command line in $EDITOR
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line
